# =========================================================
#  Extraction (LLM)
# =========================================================
# Pick provider via CAIRN_EXTRACTION_PROVIDER, or set credentials
# and let auto-detection choose (gateway > anthropic > null).

# --- Option A: Vercel AI Gateway (recommended) ---
# Routes to any model via provider/model ids.
# Example models:
#   anthropic/claude-haiku-4-5-20251001
#   anthropic/claude-sonnet-4-7
#   openai/gpt-5-mini
#   google/gemini-2.5-flash
#   meta/llama-3.3-70b
AI_GATEWAY_API_KEY=
# Optional override (defaults shown):
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# CAIRN_EXTRACTION_PROVIDER=gateway
# CAIRN_EXTRACTION_MODEL=anthropic/claude-haiku-4-5-20251001

# --- Option B: direct Anthropic ---
# Used automatically if no AI_GATEWAY_API_KEY but ANTHROPIC_API_KEY is set.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Option C: on-device (Phase 2 distilled model) ---
# CAIRN_EXTRACTION_PROVIDER=local
# CAIRN_EXTRACTION_MODEL=qwen2.5-1.5b-extract
# CAIRN_LOCAL_ENDPOINT=http://localhost:8080/v1
# CAIRN_LOCAL_API_KEY=

# =========================================================
#  Embeddings (Phase 2 vector retrieval)
# =========================================================
# Defaults to the Vercel Gateway with openai/text-embedding-3-small @ 1024d.
# CAIRN_EMBEDDING_PROVIDER=gateway
# CAIRN_EMBEDDING_MODEL=openai/text-embedding-3-small
# CAIRN_EMBEDDING_DIM=1024

# =========================================================
#  Consolidation (Phase 2 hierarchical memory)
# =========================================================
# Used by the sleep-time consolidation worker to summarise episodic memories.
# A stronger model is recommended here than for extraction.
# CAIRN_CONSOLIDATION_MODEL=anthropic/claude-sonnet-4-7
# CAIRN_CONSOLIDATION_INTERVAL_SECS=900     # 15 min idle → run

# =========================================================
#  Data + Logging
# =========================================================
# CAIRN_DATA_DIR=/Users/you/Library/Application Support/Cairn
# CAIRN_LOG=info,cairn_lib=debug
